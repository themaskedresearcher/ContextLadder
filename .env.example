# Copy to `.env` and fill in the keys for the provider(s) you use.
# scripts/run_contextladder.py loads this file automatically (python-dotenv).
#
# Provider <-> key mapping (see src/llm_runner/runner.py):
#   --provider anthropic   -> ANTHROPIC_API_KEY   (Claude models)
#   --provider openai      -> OPENAI_API_KEY
#   --provider deepseek    -> DEEPSEEK_API_KEY     (base_url https://api.deepseek.com)
#   --provider openrouter  -> OPENROUTER_API_KEY   (base_url https://openrouter.ai/api/v1)

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
